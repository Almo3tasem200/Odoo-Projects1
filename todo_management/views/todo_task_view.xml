<odoo>

    <!-- List View-->
    <record id="todo_task_view_tree" model="ir.ui.view">
        <field name="name">todo task tree</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <tree class="header_custom" decoration-danger="is_late" decoration-success="state == 'completed'" multi_edit="1">
                <field name="name"/>
                <field name="assign_to_id"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="is_late"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View-->
    <record id="todo_task_view_form" model="ir.ui.view">
        <field name="name">todo task form</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="state != 'completed' or not active"/>
                    <widget name="web_ribbon" title="Closed" bg_color="text-bg-dark" invisible="state != 'closed' or not active"/>
                    <header>
                        <button name="action_in_progress" type="object" class="btn-primary btn-sm" string="In Progress ..."
                            invisible="state != 'new'"/>
                        <button name="action_new" type="object" class="btn-secondary btn-sm" string="New"
                            invisible="state in ('new', 'closed')"/>
                        <button name="action_completed" type="object" class="btn-success btn-sm" string="Completed"
                            invisible="state != 'in_progress'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="state != 'new'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="created_time" readonly="1" />
                            <field name="updated_time" readonly="1"/>
                            <field name="due_date" readonly="state == 'closed'"/>
                        </group>
                        <group>
                            <field name="assign_to_id" readonly="state == 'closed'"/>
                        </group>
                        <group>
                            <field name="estimated_time" readonly="state == 'closed'"/>
                            <field name="active" readonly="state == 'closed'" />
                            <field name="is_late" invisible="1" readonly="state == 'closed'"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" groups="todo_management.task_manager_group"/>
<!--                        <field name="estimated_time"/>-->
<!--                        <field name="total_time"/>-->
                    </group>
                    <notebook>
                        <page string="Timesheets">
                            <field name="timesheet_ids" readonly="state == 'closed'">
                                <tree editable="bottom">
                                    <field name="day"/>
                                    <field name="description"/>
                                    <field name="hours"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="todo_task_view_search" model="ir.ui.view">
        <field name="name">todo task search</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="assign_to_id"/>

                <filter name="state_new" string="New" domain="[('state','=','new')]"/>
                <filter name="state_in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <filter name="state_completed" string="Completed" domain="[('state','=','completed')]"/>


                <filter name="Assign_to_group" string="Assign To" context="{'group_by':'assign_to_id'}"/>
                <filter name="State_group" string="Status" context="{'group_by':'state'}"/>
                <filter name="Due_date_group" string="Due Date" context="{'group_by':'due_date'}"/>
            </search>
        </field>
    </record>




    <!-- Action -->
    <record id="todo_task_action" model="ir.actions.act_window">
        <field name="name">ToDo Task</field>
        <field name="res_model">todo.task</field>
    </record>

    <record id="task_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>

    <record id="check_due_date_cron" model="ir.cron">
        <field name="name">todo_task: Check due date</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">model.check_due_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <!--calling every day 1 time per day
        (-1 means unlimited)-->
    </record>

    <record id="task_change_states_action" model="ir.actions.server">
        <field name="name">Change States</field>
        <field name="model_id" ref="model_todo_task"/>
        <field name="binding_model_id" ref="model_todo_task"/>
        <field name="state">code</field>
        <field name="code">
            if record:
                action = record.action_change_states_wizard()

        </field>
    </record>

     <menuitem
            id="all_task_menu_item"
            name="All Tasks"
            parent="todo_menu"
            action="todo_task_action"
    />
</odoo>